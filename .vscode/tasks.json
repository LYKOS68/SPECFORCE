{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SPECFORCE: Neue Session starten",
      "type": "shell",
      "command": "bash scripts/init-session.sh",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "SPECFORCE: Session fortsetzen",
      "type": "shell",
      "command": "bash scripts/resume-session.sh",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "SPECFORCE: Prompt-Kaskade ausführen",
      "type": "shell",
      "command": "bash scripts/run-cascade.sh ${input:cascadeName}",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "SPECFORCE: Session-Status anzeigen",
      "type": "shell",
      "command": "bash scripts/session-status.sh",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "SPECFORCE: Session archivieren",
      "type": "shell",
      "command": "bash scripts/archive-session.sh",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "cascadeName",
      "description": "Name der Prompt-Kaskade",
      "default": "basis",
      "type": "promptString"
    }
  ]
}
